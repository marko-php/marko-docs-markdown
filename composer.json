{
    "name": "marko/docs-markdown",
    "description": "Canonical Marko documentation content package",
    "license": "MIT",
    "type": "library",
    "require": {
        "php": "^8.5",
        "marko/core": "self.version"
    },
    "require-dev": {
        "pestphp/pest": "^4.0"
    },
    "autoload": {
        "psr-4": {
            "Marko\\DocsMarkdown\\": "src/"
        }
    },
    "autoload-dev": {
        "psr-4": {
            "Marko\\DocsMarkdown\\Tests\\": "tests/"
        }
    },
    "config": {
        "allow-plugins": {
            "pestphp/pest-plugin": true
        }
    },
    "extra": {
        "marko": {
            "module": true
        }
    }
}
